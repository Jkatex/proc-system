{
  "name": "procurement-platform",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Canonical monorepo for the ProcureX production platform.",
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm --workspace server run dev",
    "dev:server:example": "npm --workspace server run dev:example",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace shared run build && npm --workspace server run build && npm --workspace client run build",
    "build:client": "npm --workspace shared run build && npm --workspace client run build",
    "test": "npm --workspace server test && npm --workspace client test",
    "test:client": "npm --workspace client run test",
    "lint:client": "npm --workspace client run lint",
    "generate:client:procurex-pages": "npm --workspace client run generate:procurex-pages",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:validate": "npm --workspace server run db:validate",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:deploy": "npm --workspace server run db:deploy",
    "db:seed": "npm --workspace server run db:seed",
    "db:seed:marketplace-demo": "npm --workspace server run db:seed:marketplace-demo",
    "db:seed:awards-demo": "npm --workspace server run db:seed:award-contract-demo",
    "db:cleanup:demo-admin": "npm --workspace server run db:cleanup:demo-admin",
    "db:seed:twice": "npm --workspace server run db:seed:twice"
  },
  "engines": {
    "node": ">=20.11"
  }
}
