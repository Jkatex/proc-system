{
  "name": "@procurex/server",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "ProcureX TypeScript Express backend and Prisma database foundation.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:cleanup:demo-admin": "tsx prisma/cleanup-demo-admin-only.ts",
    "db:seed:twice": "npm run db:seed && npm run db:seed",
    "verify:rls": "tsx src/verify-rls.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.699.0",
    "@elastic/elasticsearch": "^8.15.2",
    "@prisma/client": "^6.19.3",
    "@procurex/shared": "0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "nodemailer": "^8.0.10",
    "twilio": "^6.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.19.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11"
  }
}
