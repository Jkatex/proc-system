generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "organization", "procurement", "bidding", "evaluation", "contract", "financial", "compliance", "communication", "documents", "records", "intelligence", "integration", "content"]
}

enum AccountType {
  USER
  ADMIN

  @@schema("identity")
}

enum VerificationStatus {
  NOT_STARTED
  DRAFT
  PENDING
  APPROVED
  REJECTED
  EXPIRED

  @@schema("identity")
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED

  @@schema("identity")
}

enum PublicPageKey {
  ABOUT_PROCUREX
  PRIVACY_POLICY
  TERMS_AND_CONDITIONS

  @@schema("content")
}

enum PublicPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@schema("content")
}

enum OrganizationKind {
  COMPANY
  PLATFORM

  @@schema("organization")
}

enum OrganizationCapabilityName {
  BUYER
  SUPPLIER

  @@schema("organization")
}

enum MemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED

  @@schema("organization")
}

enum TrustTier {
  UNVERIFIED
  VERIFIED
  BRONZE
  SILVER
  GOLD
  PLATINUM

  @@schema("organization")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@schema("organization")
}

enum TenderType {
  GOODS
  WORKS
  SERVICE
  CONSULTANCY

  @@schema("procurement")
}

enum TenderStatus {
  DRAFT
  REVIEW
  PUBLISHED
  OPEN
  CLOSED
  EVALUATION
  AWARDED
  CANCELLED

  @@schema("procurement")
}

enum ProcurementMethod {
  OPEN_TENDER
  INVITED_TENDER

  @@schema("procurement")
}

enum Visibility {
  PRIVATE
  INVITED
  PUBLIC_MARKETPLACE

  @@schema("procurement")
}

enum ContractType {
  UNIT_PRICE
  LUMP_SUM
  FRAMEWORK
  TIME_AND_MATERIALS
  OTHER

  @@schema("procurement")
}

enum BidStatus {
  DRAFT
  SUBMITTED
  WITHDRAWN
  OPENED
  UNDER_EVALUATION
  DISQUALIFIED
  AWARDED
  LOST

  @@schema("bidding")
}

enum EnvelopeType {
  TECHNICAL
  FINANCIAL
  COMBINED

  @@schema("bidding")
}

enum DocumentReviewStatus {
  UPLOADED
  VERIFIED
  REVIEW
  REJECTED

  @@schema("documents")
}

enum EvaluationStatus {
  NOT_STARTED
  IN_PROGRESS
  LOCKED
  COMPLETED
  RETURNED

  @@schema("evaluation")
}

enum EvaluationStage {
  OPENING
  CONFLICT
  PRELIMINARY
  ELIGIBILITY
  TECHNICAL
  FINANCIAL
  CLARIFICATIONS
  COMPARISON
  REPORT
  RECOMMENDATION

  @@schema("evaluation")
}

enum WorkflowAssignmentType {
  EVALUATOR
  APPROVER
  AUDITOR
  OBSERVER

  @@schema("evaluation")
}

enum ApprovalStatus {
  WAITING
  PENDING
  APPROVED
  RETURNED
  REJECTED

  @@schema("evaluation")
}

enum RecommendationStatus {
  DRAFT
  RECOMMENDED
  APPROVED
  RETURNED
  REJECTED

  @@schema("evaluation")
}

enum ContractStatus {
  DRAFT
  NEGOTIATION
  SIGNATURE_PENDING
  ACTIVE
  COMPLETED
  TERMINATED

  @@schema("contract")
}

enum SignatureStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED

  @@schema("contract")
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  MATCHED
  REVIEW
  BLOCKED
  PAID
  REJECTED

  @@schema("financial")
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL

  @@schema("compliance")
}

enum ComplianceCaseStatus {
  OPEN
  INVESTIGATION
  FALSE_POSITIVE
  RESOLVED
  ESCALATED

  @@schema("compliance")
}

enum AdminActionType {
  REVIEW
  APPROVE
  RETURN
  HOLD
  FLAG
  EXPORT

  @@schema("compliance")
}

enum CommunicationKind {
  MESSAGE
  CLARIFICATION
  NOTIFICATION
  ALERT

  @@schema("communication")
}

enum CommunicationPriority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@schema("communication")
}

enum CommunicationStatus {
  UNREAD
  READ
  REPLIED
  PENDING_RESPONSE
  RESOLVED
  ARCHIVED
  DELETED
  ACTION_REQUIRED
  COMPLETED

  @@schema("communication")
}

model User {
  id                   String                  @id @default(uuid()) @db.Uuid
  email                String                  @unique
  phone                String?
  displayName          String                  @map("display_name")
  passwordHash         String?                 @map("password_hash")
  accountType          AccountType             @default(USER) @map("account_type")
  verificationStatus   VerificationStatus      @default(NOT_STARTED) @map("verification_status")
  metadata             Json                    @default("{}")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")
  accounts             Account[]
  sessions             Session[]
  policyAcceptances    UserPolicyAcceptance[]
  mfaFactors           MfaFactor[]
  identityChallenges   IdentityChallenge[]
  memberships          OrganizationMember[]
  verificationProfiles VerificationProfile[]
  verificationHistory  VerificationProfileHistory[]
  digitalSignatures    DigitalSignature[]
  uploadedDocuments    DocumentObject[]        @relation("DocumentUploader")
  ownedTenders         Tender[]                @relation("TenderOwner")
  submittedBids        Bid[]                   @relation("BidSubmitter")
  workflowAssignments  WorkflowAssignment[]
  evaluationScores     EvaluationScore[]       @relation("EvaluationScoreEvaluator")
  auditEvents          AuditEvent[]            @relation("AuditActor")
  adminActions         AdminAction[]           @relation("AdminActionActor")

  @@map("users")
  @@schema("identity")
}

model Account {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  provider       String      @default("password")
  providerUserId String?     @map("provider_user_id")
  accountType    AccountType @default(USER) @map("account_type")
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at")
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("accounts")
  @@schema("identity")
}

model UserPolicyAcceptance {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  termsVersionId   String            @map("terms_version_id") @db.Uuid
  privacyVersionId String            @map("privacy_version_id") @db.Uuid
  acceptedAt       DateTime          @default(now()) @map("accepted_at")
  source           String            @default("registration")
  ipAddress        String?           @map("ip_address")
  userAgent        String?           @map("user_agent")
  payload          Json              @default("{}")
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  termsVersion     PublicPageVersion @relation("TermsPolicyAcceptances", fields: [termsVersionId], references: [id], onDelete: Restrict)
  privacyVersion   PublicPageVersion @relation("PrivacyPolicyAcceptances", fields: [privacyVersionId], references: [id], onDelete: Restrict)

  @@index([userId, acceptedAt])
  @@index([termsVersionId])
  @@index([privacyVersionId])
  @@map("user_policy_acceptances")
  @@schema("identity")
}

model Session {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  tokenHash      String        @map("token_hash")
  status         SessionStatus @default(ACTIVE)
  expiresAt      DateTime      @map("expires_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([organizationId])
  @@map("sessions")
  @@schema("identity")
}

model MfaFactor {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  secretRef String?  @map("secret_ref")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_factors")
  @@schema("identity")
}

model IdentityChallenge {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  purpose    String
  target     String
  codeHash   String    @map("code_hash")
  status     String    @default("PENDING")
  attempts   Int       @default(0)
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  metadata   Json      @default("{}")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, status])
  @@index([target, purpose, status])
  @@map("identity_challenges")
  @@schema("identity")
}

model VerificationProfile {
  id             String             @id @default(uuid()) @db.Uuid
  userId         String             @map("user_id") @db.Uuid
  organizationId String?            @map("organization_id") @db.Uuid
  status         VerificationStatus @default(DRAFT)
  registrySource String?            @map("registry_source")
  registryNumber String?            @map("registry_number")
  payload        Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  documents      VerificationDocument[]
  digitalSignatures DigitalSignature[]
  history       VerificationProfileHistory[]

  @@index([userId])
  @@index([organizationId, status])
  @@map("verification_profiles")
  @@schema("identity")
}

model VerificationProfileHistory {
  id                    String              @id @default(uuid()) @db.Uuid
  verificationProfileId String              @map("verification_profile_id") @db.Uuid
  userId                String              @map("user_id") @db.Uuid
  organizationId        String?             @map("organization_id") @db.Uuid
  status                VerificationStatus
  registrySource        String?             @map("registry_source")
  registryNumber        String?             @map("registry_number")
  event                 String
  payload               Json                @default("{}")
  createdAt             DateTime            @default(now()) @map("created_at")
  verificationProfile   VerificationProfile @relation(fields: [verificationProfileId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([verificationProfileId, createdAt])
  @@index([userId, createdAt])
  @@map("verification_profile_history")
  @@schema("identity")
}

model DigitalSignature {
  id                    String              @id @default(uuid()) @db.Uuid
  verificationProfileId String              @map("verification_profile_id") @db.Uuid
  userId                String              @map("user_id") @db.Uuid
  organizationId        String?             @map("organization_id") @db.Uuid
  signerName            String              @map("signer_name")
  signerTitle           String?             @map("signer_title")
  consentVersion        String              @map("consent_version")
  consentTitle          String              @map("consent_title")
  canonicalPayloadHash  String              @map("canonical_payload_hash")
  signatureHash         String              @map("signature_hash")
  status                String              @default("SIGNED")
  signedAt              DateTime            @default(now()) @map("signed_at")
  metadata              Json                @default("{}")
  providerMetadata      Json                @default("{}") @map("provider_metadata")
  blockchainMetadata    Json                @default("{}") @map("blockchain_metadata")
  createdAt             DateTime            @default(now()) @map("created_at")
  verificationProfile   VerificationProfile @relation(fields: [verificationProfileId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([verificationProfileId, signedAt])
  @@index([userId, signedAt])
  @@index([signatureHash])
  @@map("digital_signatures")
  @@schema("identity")
}

model VerificationDocument {
  id                    String               @id @default(uuid()) @db.Uuid
  verificationProfileId String               @map("verification_profile_id") @db.Uuid
  documentId            String               @map("document_id") @db.Uuid
  status                DocumentReviewStatus @default(UPLOADED)
  createdAt             DateTime             @default(now()) @map("created_at")
  verificationProfile   VerificationProfile  @relation(fields: [verificationProfileId], references: [id], onDelete: Cascade)
  document              DocumentObject       @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([verificationProfileId])
  @@index([documentId])
  @@map("verification_documents")
  @@schema("identity")
}

model Organization {
  id                   String                    @id @default(uuid()) @db.Uuid
  name                 String                    @unique
  kind                 OrganizationKind          @default(COMPANY)
  taxId                String?                   @map("tax_id")
  country              String                    @default("TZ")
  metadata             Json                      @default("{}")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  members              OrganizationMember[]
  capabilities         OrganizationCapability[]
  profile              OrganizationProfile?
  buyerProfile         BuyerProfile?
  supplierProfile      SupplierProfile?
  sessions             Session[]
  verificationProfiles VerificationProfile[]
  verificationHistory  VerificationProfileHistory[]
  digitalSignatures    DigitalSignature[]
  documents            DocumentObject[]
  tendersAsBuyer       Tender[]                  @relation("TenderBuyerOrg")
  bidsAsBuyer          Bid[]                     @relation("BidBuyerOrg")
  bidsAsSupplier       Bid[]                     @relation("BidSupplierOrg")
  evaluationWorkspaces EvaluationWorkspace[]     @relation("EvaluationBuyerOrg")
  contractsAsBuyer     Contract[]                @relation("ContractBuyerOrg")
  contractsAsSupplier  Contract[]                @relation("ContractSupplierOrg")
  purchaseOrders       PurchaseOrder[]           @relation("PurchaseOrderBuyerOrg")
  invoicesAsBuyer      Invoice[]                 @relation("InvoiceBuyerOrg")
  invoicesAsSupplier   Invoice[]                 @relation("InvoiceSupplierOrg")
  communicationOwned   CommunicationItem[]       @relation("CommunicationOwnerOrg")
  communicationSent    CommunicationItem[]       @relation("CommunicationSenderOrg")
  communicationReceived CommunicationItem[]      @relation("CommunicationRecipientOrg")
  auditEvents          AuditEvent[]
  complianceCases      ComplianceCase[]
  adminActions         AdminAction[]

  @@index([kind])
  @@map("organizations")
  @@schema("organization")
}

model OrganizationMember {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  status         MemberStatus @default(ACTIVE)
  title          String?
  isDefault      Boolean      @default(true) @map("is_default")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
  @@schema("organization")
}

model OrganizationCapability {
  id             String                     @id @default(uuid()) @db.Uuid
  organizationId String                     @map("organization_id") @db.Uuid
  capability     OrganizationCapabilityName
  enabled        Boolean                    @default(true)
  createdAt      DateTime                   @default(now()) @map("created_at")
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, capability])
  @@index([capability, enabled])
  @@map("organization_capabilities")
  @@schema("organization")
}

model OrganizationProfile {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @map("organization_id") @db.Uuid
  summary        String?
  payload        Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_profiles")
  @@schema("organization")
}

model BuyerProfile {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @map("organization_id") @db.Uuid
  procuringType  String?      @map("procuring_type")
  budgetCode     String?      @map("budget_code")
  payload        Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("buyer_profiles")
  @@schema("organization")
}

model SupplierProfile {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @map("organization_id") @db.Uuid
  trustTier      TrustTier    @default(UNVERIFIED) @map("trust_tier")
  riskLevel      RiskLevel    @default(MEDIUM) @map("risk_level")
  bidLimit       Decimal?     @map("bid_limit") @db.Decimal(18, 2)
  categories     Json         @default("[]")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("supplier_profiles")
  @@schema("organization")
}

model Tender {
  id              String              @id @default(uuid()) @db.Uuid
  reference       String              @unique
  buyerOrgId      String              @map("buyer_org_id") @db.Uuid
  ownerUserId     String?             @map("owner_user_id") @db.Uuid
  title           String
  description     String?
  type            TenderType
  status          TenderStatus        @default(DRAFT)
  method          ProcurementMethod   @default(OPEN_TENDER)
  visibility      Visibility          @default(PUBLIC_MARKETPLACE)
  budget          Decimal?            @db.Decimal(18, 2)
  currency        String              @default("TZS")
  location        String?
  contractType    ContractType?       @map("contract_type")
  closingDate     DateTime?           @map("closing_date")
  publishedAt     DateTime?           @map("published_at")
  requirements    Json                @default("{}")
  metadata        Json                @default("{}")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  buyerOrg        Organization        @relation("TenderBuyerOrg", fields: [buyerOrgId], references: [id], onDelete: Restrict)
  ownerUser       User?               @relation("TenderOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  categories      TenderCategory[]
  documents       TenderDocument[]
  requirementRows TenderRequirement[]
  milestones      TenderMilestone[]
  commercialItems TenderCommercialItem[]
  bids            Bid[]
  evaluation      EvaluationWorkspace?
  communications  CommunicationItem[]
  contracts       Contract[]
  riskSignals     RiskSignal[]
  supplierMatches SupplierMatchSignal[]

  @@index([buyerOrgId, status])
  @@index([status, type, closingDate])
  @@map("tenders")
  @@schema("procurement")
}

model TenderCategory {
  id        String     @id @default(uuid()) @db.Uuid
  tenderId  String?    @map("tender_id") @db.Uuid
  type      TenderType?
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  tender    Tender?    @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([tenderId, name])
  @@unique([type, name])
  @@map("tender_categories")
  @@schema("procurement")
}

model TenderDocument {
  id         String         @id @default(uuid()) @db.Uuid
  tenderId   String         @map("tender_id") @db.Uuid
  documentId String         @map("document_id") @db.Uuid
  label      String?
  createdAt  DateTime       @default(now()) @map("created_at")
  tender     Tender         @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  document   DocumentObject @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@unique([tenderId, documentId])
  @@index([documentId])
  @@map("tender_documents")
  @@schema("procurement")
}

model TenderRequirement {
  id        String   @id @default(uuid()) @db.Uuid
  tenderId  String   @map("tender_id") @db.Uuid
  section   String
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId, section])
  @@map("tender_requirements")
  @@schema("procurement")
}

model TenderMilestone {
  id        String    @id @default(uuid()) @db.Uuid
  tenderId  String    @map("tender_id") @db.Uuid
  name      String
  dueDate   DateTime? @map("due_date")
  payload   Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  tender    Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId, dueDate])
  @@map("tender_milestones")
  @@schema("procurement")
}

model TenderCommercialItem {
  id          String   @id @default(uuid()) @db.Uuid
  tenderId    String   @map("tender_id") @db.Uuid
  itemNo      String?  @map("item_no")
  description String
  quantity    Decimal? @db.Decimal(18, 4)
  unit        String?
  rate        Decimal? @db.Decimal(18, 2)
  total       Decimal? @db.Decimal(18, 2)
  payload     Json     @default("{}")
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId])
  @@map("tender_commercial_items")
  @@schema("procurement")
}

model Bid {
  id              String       @id @default(uuid()) @db.Uuid
  tenderId        String       @map("tender_id") @db.Uuid
  buyerOrgId      String       @map("buyer_org_id") @db.Uuid
  supplierOrgId   String       @map("supplier_org_id") @db.Uuid
  submittedByUserId String?    @map("submitted_by_user_id") @db.Uuid
  reference       String       @unique
  status          BidStatus    @default(DRAFT)
  submittedAt     DateTime?    @map("submitted_at")
  totalAmount     Decimal?     @map("total_amount") @db.Decimal(18, 2)
  currency        String       @default("TZS")
  payload         Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  tender          Tender       @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  buyerOrg        Organization @relation("BidBuyerOrg", fields: [buyerOrgId], references: [id], onDelete: Restrict)
  supplierOrg     Organization @relation("BidSupplierOrg", fields: [supplierOrgId], references: [id], onDelete: Restrict)
  submittedByUser User?        @relation("BidSubmitter", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  versions        BidVersion[]
  documents       BidDocument[]
  responses       BidResponse[]
  receipt         BidReceipt?
  evaluationScores EvaluationScore[]
  recommendations AwardRecommendation[]

  @@index([tenderId, status])
  @@index([buyerOrgId, status])
  @@index([supplierOrgId, status])
  @@map("bids")
  @@schema("bidding")
}

model BidVersion {
  id          String       @id @default(uuid()) @db.Uuid
  bidId       String       @map("bid_id") @db.Uuid
  versionNo   Int          @map("version_no")
  envelope    EnvelopeType @default(COMBINED)
  sealedHash  String?      @map("sealed_hash")
  payload     Json         @default("{}")
  createdAt   DateTime     @default(now()) @map("created_at")
  bid         Bid          @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@unique([bidId, versionNo, envelope])
  @@map("bid_versions")
  @@schema("bidding")
}

model BidDocument {
  id           String               @id @default(uuid()) @db.Uuid
  bidId        String               @map("bid_id") @db.Uuid
  documentId   String               @map("document_id") @db.Uuid
  envelope     EnvelopeType         @default(COMBINED)
  reviewStatus DocumentReviewStatus @default(UPLOADED) @map("review_status")
  createdAt    DateTime             @default(now()) @map("created_at")
  bid          Bid                  @relation(fields: [bidId], references: [id], onDelete: Cascade)
  document     DocumentObject       @relation(fields: [documentId], references: [id], onDelete: Restrict)

