model AdminAction {
  id               String          @id @default(uuid()) @db.Uuid
  actorUserId      String?         @map("actor_user_id") @db.Uuid
  ownerOrgId       String?         @map("owner_org_id") @db.Uuid
  actionType       AdminActionType @map("action_type")
  entityType       String          @map("entity_type")
  entityRef        String?         @map("entity_ref")
  summary          String?
  payload          Json            @default("{}")
  previousState    Json            @default("{}") @map("previous_state")
  nextState        Json            @default("{}") @map("next_state")
  reversible       Boolean         @default(false)
  revertedAt       DateTime?       @map("reverted_at")
  revertedByUserId String?         @map("reverted_by_user_id") @db.Uuid
  reverseActionId  String?         @map("reverse_action_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  actorUser        User?           @relation("AdminActionActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  ownerOrg         Organization?   @relation(fields: [ownerOrgId], references: [id], onDelete: SetNull)
  revertedByUser   User?           @relation("AdminActionRevertedBy", fields: [revertedByUserId], references: [id], onDelete: SetNull)
  reverseAction    AdminAction?    @relation("AdminActionReverse", fields: [reverseActionId], references: [id], onDelete: SetNull)
