model CommunicationItem {
  id             String                    @id @default(uuid()) @db.Uuid
  ownerOrgId     String?                   @map("owner_org_id") @db.Uuid
  senderOrgId    String?                   @map("sender_org_id") @db.Uuid
  recipientOrgId String?                   @map("recipient_org_id") @db.Uuid
  tenderId       String?                   @map("tender_id") @db.Uuid
  kind           CommunicationKind
  folder         String                    @default("inbox")
  category       String
  subject        String
  body           String
  status         CommunicationStatus       @default(UNREAD)
  priority       CommunicationPriority     @default(NORMAL)
  read           Boolean                   @default(false)
  actionRequired Boolean                   @default(false) @map("action_required")
  visibility     String?
  payload        Json                      @default("{}")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  ownerOrg       Organization?             @relation("CommunicationOwnerOrg", fields: [ownerOrgId], references: [id], onDelete: SetNull)
  senderOrg      Organization?             @relation("CommunicationSenderOrg", fields: [senderOrgId], references: [id], onDelete: SetNull)
  recipientOrg   Organization?             @relation("CommunicationRecipientOrg", fields: [recipientOrgId], references: [id], onDelete: SetNull)
  tender         Tender?                   @relation(fields: [tenderId], references: [id], onDelete: SetNull)
  attachments    CommunicationAttachment[]

  @@index([ownerOrgId, folder, status])
  @@index([recipientOrgId, status])
  @@index([tenderId, kind])
  @@map("communication_items")
  @@schema("communication")
}

model CommunicationAttachment {
  id                  String            @id @default(uuid()) @db.Uuid
  communicationItemId String            @map("communication_item_id") @db.Uuid
  documentId          String            @map("document_id") @db.Uuid
  createdAt           DateTime          @default(now()) @map("created_at")
  communicationItem   CommunicationItem @relation(fields: [communicationItemId], references: [id], onDelete: Cascade)
  document            DocumentObject    @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@unique([communicationItemId, documentId])
  @@index([documentId])
  @@map("communication_attachments")
  @@schema("communication")
}

model SupportTicket {
